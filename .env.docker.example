# Docker Environment Configuration for MyBibliotheca
# Copy this file to .env and fill in your values

# REQUIRED: Security Configuration
# Generate secure values using: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here
SECURITY_PASSWORD_SALT=your-salt-here

# Application Settings
TIMEZONE=UTC
FLASK_DEBUG=false
# Password policy (minimum allowed 8, maximum 128)
PASSWORD_MIN_LENGTH=12

# KuzuDB Configuration (DO NOT CHANGE for Docker)
KUZU_DB_PATH=/app/data/kuzu
GRAPH_DATABASE_ENABLED=true

# Worker Configuration (DO NOT CHANGE - KuzuDB requires single worker)
WORKERS=1

# Logging Configuration
MYBIBLIOTHECA_VERBOSE_INIT=false

# Migration Settings (usually disabled in Docker)
AUTO_MIGRATE=false
MIGRATION_DEFAULT_USER=admin

# Optional: Reading streak settings
READING_STREAK_OFFSET=0

# Optional: KuzuDB maximum database size (Raspberry Pi / ARM)
# KuzuDB reserves max_db_size upfront via sparse mmap (default: 8 TiB).
# This works on x86-64 but crashes on ARM with "Mmap for size ... failed".
# Default here is 4 GB which is ample for a personal library on any platform.
# Increase to 8 or 16 if you have a very large collection.
# Set to 0 to use KuzuDB's default 8 TiB (only safe on x86-64).
KUZU_MAX_DB_SIZE_GB=4

# Optional: Metadata API Keys
# Google Books API key - avoids shared-project quota limits (HTTP 429 errors on ISBN lookup)
# Get a free key at https://console.cloud.google.com/ → APIs & Services → Books API
# GOOGLE_BOOKS_API_KEY=your-google-books-api-key
